{
    "name": "sadio-kanoute/test-unitaire-debutant",
    "description": "Projet simple de test unitaire PHP avec PHPUnit.",
    "type": "project",
    "require": {},
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}
